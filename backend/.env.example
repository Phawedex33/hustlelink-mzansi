# App environment
FLASK_ENV=development
APP_ENV=development

# Core secrets (replace with strong random values in real environments)
SECRET_KEY=replace-with-strong-secret-key
JWT_SECRET_KEY=replace-with-64-byte-random-hex

# Database
DATABASE_URL=sqlite:///hlm.db

# Rate limiting
RATELIMIT_ENABLED=true
# In production, use shared storage like Redis:
RATELIMIT_STORAGE_URI=memory://
AUTH_LOGIN_RATE_LIMIT=10 per minute
AUTH_REFRESH_ROTATION_ENABLED=true
# Temporary no-shell bootstrap (remove after first successful deploy)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Platform Admin

# CORS and web security hardening
CORS_ENABLED=true
# In production, set explicit frontend origins (no wildcard):
CORS_ORIGINS=http://localhost:3000
CORS_SUPPORTS_CREDENTIALS=false
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SECURITY_HEADERS_ENABLED=true

# Revoked token cleanup
TOKEN_CLEANUP_ENABLED=true
TOKEN_CLEANUP_INTERVAL_MINUTES=60
