{
  "info": {
    "name": "HustleLink Auth API",
    "_postman_id": "ac93d79d-4ad3-4a31-8906-9c5f9a3f8e00",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Runnable auth flows: register/login/me, refresh rotation, logout revocation, and role checks."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "provider_email",
      "value": "provider.postman@example.com"
    },
    {
      "key": "provider_password",
      "value": "Pass1234!"
    },
    {
      "key": "admin_email",
      "value": "admin@example.com"
    },
    {
      "key": "admin_password",
      "value": "AdminPass123!"
    },
    {
      "key": "provider_access_token",
      "value": ""
    },
    {
      "key": "provider_refresh_token",
      "value": ""
    },
    {
      "key": "provider_old_refresh_token",
      "value": ""
    },
    {
      "key": "admin_access_token",
      "value": ""
    },
    {
      "key": "admin_refresh_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Provider Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{provider_email}}\",\n  \"password\": \"{{provider_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Provider Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('provider_access_token', body.access_token || '');",
              "  pm.collectionVariables.set('provider_refresh_token', body.refresh_token || '');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{provider_email}}\",\n  \"password\": \"{{provider_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Provider Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Provider Ping (Allowed)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/provider/ping",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "provider",
            "ping"
          ]
        }
      }
    },
    {
      "name": "Admin Ping With Provider Token (Forbidden)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/admin/ping",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "admin",
            "ping"
          ]
        }
      }
    },
    {
      "name": "Refresh (Rotate Token Pair)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('provider_old_refresh_token', pm.collectionVariables.get('provider_refresh_token') || '');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('provider_access_token', body.access_token || '');",
              "  pm.collectionVariables.set('provider_refresh_token', body.refresh_token || '');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_refresh_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/refresh",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        }
      }
    },
    {
      "name": "Refresh Reuse Old Token (Should Fail)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_old_refresh_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/refresh",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        }
      }
    },
    {
      "name": "Logout (Revoke Access Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/logout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        }
      }
    },
    {
      "name": "Me With Revoked Token (Should Fail)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('admin_access_token', body.access_token || '');",
              "  pm.collectionVariables.set('admin_refresh_token', body.refresh_token || '');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/admin/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "admin",
            "login"
          ]
        }
      }
    },
    {
      "name": "Admin Ping (Allowed)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/admin/ping",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "admin",
            "ping"
          ]
        }
      }
    }
  ]
}
